##############################
# Git 忽略文件配置
# 指定 Git 在版本控制中应忽略的文件或目录
##############################

##############################
# 依赖管理
##############################
# 依赖包目录，包含所有已安装的依赖项
node_modules/

# 包管理器相关缓存目录
.pnpm-store/
.npm/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# 忽略包锁定文件
pnpm-lock.yaml
package-lock.json
yarn.lock

##############################
# 构建输出
##############################
# 标准构建输出目录
/dist/
# Vite 特有的构建输出
/dist-ssr/
# 测试覆盖率报告
/coverage/
# Nuxt.js 构建输出
/.nuxt/
# Storybook 构建输出
/storybook-static/
# Vue-cli 相关生成文件
/.vite/

##############################
# 日志文件
##############################
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

##############################
# 缓存文件
##############################
.eslintcache
.stylelintcache
.node_repl_history
# TypeScript 增量编译缓存
*.tsbuildinfo
# Vue 类型检查缓存
.vue-tsc/

##############################
# 本地配置或敏感文件
##############################
# 本地环境变量文件，包含敏感信息如API密钥
.env.local
.env.*.local
# 包含个人配置的文件
*.local

##############################
# 系统文件
##############################
# macOS系统文件
.DS_Store
# Windows系统文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

##############################
# 编辑器和IDE文件
##############################
# VSCode配置文件，但保留推荐扩展
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
# WebStorm/IntelliJ IDEA配置文件
.idea/
# Visual Studio文件
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Sublime Text项目和工作区文件
*.sublime-project
*.sublime-workspace
# Vim交换文件
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-v][a-z]
[._]sw[a-p]

##############################
# 自动化测试
##############################
# Cypress测试生成的媒体文件
/cypress/videos/
/cypress/screenshots/
# Playwright测试生成的文件
/test-results/
/playwright-report/
/playwright/.cache/

##############################
# 临时文件
##############################
# 默认临时目录
/tmp/
/temp/
