# Git 属性配置文件
# 用于配置 Git 如何处理不同类型的文件
# 详情参考: https://git-scm.com/docs/gitattributes

# 全局默认设置
# text=auto: 自动识别文本文件，并做标准化处理（CRLF 转换为 LF）
# eol=lf: 指定文本文件以 LF (Unix 风格) 结尾
* text=auto eol=lf

###############################
# Git 行为配置
###############################

# 确保 shell 脚本使用 LF 行尾，保证在 Unix 系统上可执行
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Windows 特定文件使用 CRLF 行尾
*.bat text eol=crlf
*.cmd text eol=crlf

###############################
# 二进制文件（不进行 text 处理）
###############################

# 图片文件（不做任何行尾转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text

# 字体文件
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary

# 音频文件
*.mp3 binary
*.wav binary
*.ogg binary

# 视频文件
*.mp4 binary
*.webm binary

# 文档文件
*.pdf binary

# 压缩文件
*.zip binary
*.gz binary
*.tar binary

###############################
# 差异化处理配置
###############################

# 不在差异比较中包含的文件（比如生成的文件）
package-lock.json -diff
pnpm-lock.yaml -diff
yarn.lock -diff
*.min.js -diff
*.min.css -diff

# 使用特定差异化比较方式的文件
*.md diff=markdown

###############################
# 标记为导出时排除的文件
###############################

# 开发工具配置不包含在导出包中
.editorconfig export-ignore
.eslintrc.* export-ignore
.prettier* export-ignore
.gitattributes export-ignore
.gitignore export-ignore
.gitlab-ci.yml export-ignore
.github/ export-ignore
